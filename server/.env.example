# ERPPlus 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=3001

# JWT 密钥（必须设置，至少32字符）
# 生成强密钥：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# GLM AI 大模型 API 密钥
# 请在 https://open.bigmodel.cn/ 注册并获取 API Key
GLM_API_KEY=your-glm-api-key-here

# 日志级别（可选）
# 可选值：error, warn, info, http, debug
# 生产环境建议：info，开发环境建议：debug
LOG_LEVEL=debug

# Node 环境（可选）
NODE_ENV=development
